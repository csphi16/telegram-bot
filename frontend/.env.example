# Backend API URL (required)
VITE_API_URL=https://your-backend-railway-url.railway.app

# Telegram Login Widget bot username (required for real Telegram sign-in)
# Example: my_paybot (without @)
VITE_TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Supabase Configuration (optional)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
